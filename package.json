{
  "name": "phytograph",
  "private": true,
  "version": "0.19.0",
  "description": "Phytograph desktop app.",
  "author": "Phytograph",
  "main": "dist-main/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-electron-info-plist.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "gen:version": "node scripts/gen-version-info.mjs",
    "build": "npm run gen:version && npm run build:renderer && npm run build:main && npm run build:preload",
    "build:backend": "node scripts/build-backend.mjs",
    "build:potree-converter": "node scripts/build-potree-converter.mjs",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "package:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --publish always",
    "typecheck": "npm run gen:version && tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:backend": "cd backend-api && ./venv/bin/pytest",
    "test:e2e": "playwright test",
    "test": "npm run typecheck && npm run test:unit && npm run test:backend && npm run test:e2e"
  },
  "dependencies": {
    "@react-three/drei": "^10.6.1",
    "@react-three/fiber": "^9.3.0",
    "@types/gif.js": "^0.2.5",
    "@types/papaparse": "^5.3.16",
    "electron-log": "^5.4.4",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.23.12",
    "gif.js": "^0.2.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.536.0",
    "papaparse": "^5.5.3",
    "potree-core": "^2.0.15",
    "react": "^19.1.0",
    "react-data-table-component": "^7.7.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "recharts": "^3.1.2",
    "styled-components": "^6.1.19",
    "three": "^0.179.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/forms": "^0.5.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "happy-dom": "^15.11.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.phytograph.app",
    "productName": "Phytograph",
    "copyright": "© 2026 Phytograph",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-main/**/*",
      "dist-preload/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "phytograph_backend/**/*"
        ]
      },
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "potree_converter/**/*"
        ]
      },
      {
        "from": "build",
        "to": "build",
        "filter": [
          "icon.png",
          "icon.ico",
          "icon-dock.png"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "artifactName": "${productName}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-Setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "artifactName": "${productName}.${ext}",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education",
      "maintainer": "Plant Simulation Laboratory <baileylabshared@gmail.com>"
    },
    "deb": {
      "artifactName": "${productName}-amd64.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PlantSimulationLab",
        "repo": "phytograph",
        "releaseType": "draft"
      }
    ]
  }
}
