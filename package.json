{
  "name": "phytograph",
  "private": true,
  "version": "0.1.0",
  "description": "Phytograph desktop app.",
  "author": "Phytograph",
  "main": "dist-main/main.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:backend": "node scripts/build-backend.mjs",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win",
    "release": "npm run build && electron-builder --publish always",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^10.6.1",
    "@react-three/fiber": "^9.3.0",
    "@types/gif.js": "^0.2.5",
    "@types/papaparse": "^5.3.16",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.23.12",
    "gif.js": "^0.2.0",
    "katex": "^0.16.27",
    "lucide-react": "^0.536.0",
    "papaparse": "^5.5.3",
    "react": "^19.1.0",
    "react-data-table-component": "^7.7.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "recharts": "^3.1.2",
    "styled-components": "^6.1.19",
    "three": "^0.179.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.phytograph.app",
    "productName": "Phytograph",
    "copyright": "© 2026 Phytograph",
    "afterSign": "scripts/notarize.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-main/**/*",
      "dist-preload/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["phytograph_backend/**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "writeUpdateInfo": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "signingHashAlgorithms": ["sha256"]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"],
      "category": "Education"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PlantSimulationLab",
        "repo": "phytograph",
        "releaseType": "draft"
      }
    ]
  }
}
