<?xml version="1.0"?>

<!--
  Moving-platform synthetic scan of the lidar plugin's
  leaf_cube_LAI2_lw0_01_spherical geometry (LAI=2, spherical leaf
  angles). The platform translates ~2 m along +x at z=5 over the
  sweep. Per-voxel true LAD=2.0 m^2/m^3, G(theta)=0.5. Import the
  scan via Add Scan -> Import from XML, then attach trajectory.csv
  via "Import trajectory file..." to make it a moving-platform scan.
  Generated by generate_lad_leafcube_moving.py (400x650).
-->

<helios>

<scan>
  <filename> leafcube_moving.xyz </filename>
  <ASCII_format> x y z timestamp is_miss </ASCII_format>
  <origin> -1.000000 0.000000 5.000000 </origin>
  <size> 400 650 </size>
</scan>

</helios>
